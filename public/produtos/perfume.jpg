    margin: 0;
    font-size: inherit;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .signed-out-dropdown-1 ul.signed-out-dropdown {
    padding: 0.4rem 0 0.7rem 0;
    margin: 0;
